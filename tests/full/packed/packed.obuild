name: packed
version: 1.0
obuild-ver: 1
synopsis: pack:true wrapping test — two libraries with colliding member names

library liba
  modules: Util, Alpha
  src-dir: a
  pack: true

library libb
  modules: Util, Beta
  src-dir: b
  pack: true

executable main
  main-is: main.ml
  build-deps: liba, libb
